## AUTH DB (optional; default sqlite file ./auth_db.sqlite)
AUTH_DB_URL=sqlite:///./auth_db.sqlite

## JWT
AUTH_JWT_SECRET=change-me-in-prod
AUTH_JWT_EXP_MINUTES=45

## MySQL (payroll)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=payroll
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

## SQL Server (HUMAN_2025)
SQLSERVER_SERVER=localhost
SQLSERVER_DATABASE=HUMAN_2025
SQLSERVER_UID=sa
SQLSERVER_PWD=YourStrong!Passw0rd
USE_TRUSTED_CONNECTION=false

## Frontend origin(s) for CORS (comma-separated)
FRONTEND_ORIGIN=http://localhost:5173

## Optional admin account for initial bootstrap
BOOTSTRAP_ADMIN_USERNAME=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
